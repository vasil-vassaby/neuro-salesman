APP_ENV=dev
APP_URL=http://localhost:8000
LOG_LEVEL=INFO
TZ=Europe/Moscow

DATA_DIR=/app/data
KB_MD_DIR=/app/rag_md_templates

JWT_SECRET=CHANGE_ME_JWT_SECRET
COOKIE_SECRET=CHANGE_ME_COOKIE_SECRET

POSTGRES_DB=neuro_salesman
POSTGRES_USER=neuro_user
POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD
DATABASE_URL=postgresql+psycopg2://neuro_user:CHANGE_ME_DB_PASSWORD@db:5432/neuro_salesman

TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_PATH=/integrations/telegram/webhook
TELEGRAM_WEBHOOK_URL=
TELEGRAM_WEBHOOK_SECRET=CHANGE_ME_TELEGRAM_WEBHOOK_SECRET

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_CHAT_MODEL=gpt-4.1-mini
EMBEDDING_MODEL=text-embedding-3-small
RAG_ENABLED=false
EMBEDDING_DIM=1536

VITE_API_BASE_URL=http://localhost:8000/api
FRONTEND_PUBLIC_URL=http://localhost:5173
REMINDER_ENABLED=true
REMINDER_HOURS_BEFORE=24
ALLOWED_FORMATS=offline,online
ALLOWED_TIME_PREFS=day,evening
DAY_START_HOUR=9
DAY_END_HOUR=15
